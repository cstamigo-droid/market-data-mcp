# market-data-mcp configuration — copy this file to `.env` and fill in your keys.
#
# Required:
FINNHUB_API_KEY=your-finnhub-api-key-here
#
# Optional — enables the broker_positions tool (Alpaca paper trading):
# ALPACA_API_KEY=your-alpaca-key-here
# ALPACA_SECRET_KEY=your-alpaca-secret-here
#
# Get Finnhub key free at: https://finnhub.io/register
# Get Alpaca paper key at: https://app.alpaca.markets/ → Paper Trading → API Keys
